{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/auth",     "destination": "/api/auth.js" },
    { "source": "/api/callback", "destination": "/api/callback.js" },
    { "source": "/api/(.*)",     "destination": "/api/$1" }
  ],
  "redirects": [
    { "source": "/about/blog", "destination": "/blog", "permanent": true },
    { "source": "/about/blog.html", "destination": "/blog", "permanent": true },
    { "source": "/about/contact", "destination": "/contact", "permanent": true },
    { "source": "/about/contact.html", "destination": "/contact", "permanent": true }
  ]
}
